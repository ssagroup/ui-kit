{
  "name": "@ssa-ui-kit/infra-dash",
  "version": "0.4.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": false,
  "sideEffects": false,
  "author": "SSA Group",
  "license": "MIT",
  "description": "SSA UI Kit",
  "scripts": {
    "test": "NODE_OPTIONS=\"--no-webstorage\" jest -i --no-cache",
    "build": "NODE_OPTIONS=\"--no-webstorage\" webpack --mode=production --node-env=production && NODE_OPTIONS=\"--no-webstorage\" tsc --build --force ./tsconfig.build.json && NODE_OPTIONS=\"--no-webstorage\" resolve-tspaths -p ./tsconfig.build.json",
    "sb:dev": "env NODE_OPTIONS=\"--no-webstorage\" storybook dev -p 6009",
    "sb:build": "env NODE_OPTIONS=\"--no-webstorage\" storybook build",
    "test:e2e": "NODE_OPTIONS=\"--no-webstorage\" pnpm exec playwright test --project=chromium",
    "test:e2e:ui": "NODE_OPTIONS=\"--no-webstorage\" pnpm exec playwright test --project=chromium --ui",
    "test:e2e:debug": "NODE_OPTIONS=\"--no-webstorage\" pnpm exec playwright test --project=chromium --debug"
  },
  "keywords": [
    "react",
    "SSA UI Kit",
    "ui",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ssagroup/ui-kit.git",
    "directory": "packages/infra-dash"
  },
  "files": [
    "dist"
  ],
  "browserslist": [
    ">0.1%",
    "not dead",
    "not op_mini all"
  ],
  "dependencies": {
    "@ssa-ui-kit/core": "workspace:^",
    "@ssa-ui-kit/hooks": "workspace:^",
    "@grafana/data": "12.0.1",
    "react-error-boundary": "6.0.0",
    "react-grid-layout": "1.5.1",
    "react-resizable": "3.0.5",
    "@rjsf/validator-ajv8": "5.24.11",
    "@rjsf/utils": "5.24.11"
  },
  "devDependencies": {
    "@emotion/css": "11.13.5",
    "@emotion/jest": "11.14.2",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@playwright/test": "1.57.0",
    "@grafana/schema": "12.0.1",
    "@types/react-grid-layout": "1.3.5"
  },
  "peerDependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
