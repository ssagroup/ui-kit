{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsxImportSource": "@emotion/react",
    "moduleResolution": "bundler",
    "emitDeclarationOnly": false,
    "typeRoots": [
      "./src/types",
      "./node_modules/@types",
      "../../node_modules/@types"
    ],
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@components/*": ["./src/components/*"],
      "@entities/*": ["./src/entities/*"],
      "@features/*": ["./src/features/*"],
    }
  },
  "include": [
    "src/**/*",
    "./jest-setup.ts",
    "./customTest.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": [
    "dist/**/*"
  ]
}
