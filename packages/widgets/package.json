{
  "name": "@ssa-ui-kit/widgets",
  "version": "2.32.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": false,
  "sideEffects": false,
  "author": "SSA Group",
  "license": "MIT",
  "description": "SSA UI Kit widgets",
  "keywords": [
    "react",
    "SSA UI Kit",
    "widgets",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ssagroup/ui-kit.git",
    "directory": "packages/widgets"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@floating-ui/react": "0.27.4",
    "@ssa-ui-kit/core": "workspace:^",
    "@ssa-ui-kit/hooks": "workspace:^",
    "@ssa-ui-kit/utils": "workspace:^",
    "dotenv": "16.0.3",
    "loose-envify": "1.4.0"
  },
  "scripts": {
    "test": "NODE_OPTIONS=\"--max_old_space_size=8192\" jest -i --no-cache",
    "build": "NODE_OPTIONS=\"--max_old_space_size=8192\" tsc --build --force ./tsconfig.build.json && NODE_OPTIONS=\"--max_old_space_size=8192\" resolve-tspaths -p ./tsconfig.build.json",
    "sb:dev": "env NODE_OPTIONS=\"--max_old_space_size=8192\" storybook dev -p 6007",
    "sb:build": "env NODE_OPTIONS=\"--max_old_space_size=8192\" storybook build",
    "test:e2e": "NODE_OPTIONS=\"--max_old_space_size=8192\" pnpm exec playwright test --project=chromium",
    "test:e2e:ui": "NODE_OPTIONS=\"--max_old_space_size=8192\" pnpm exec playwright test --project=chromium --ui",
    "test:e2e:debug": "NODE_OPTIONS=\"--max_old_space_size=8192\" pnpm exec playwright test --project=chromium --debug",
    "ts-show-config-build": "NODE_OPTIONS=\"--max_old_space_size=8192\" tsc --showConfig -p ./tsconfig.build.json",
    "ts-show-config": "NODE_OPTIONS=\"--max_old_space_size=8192\" tsc --showConfig -p ./tsconfig.json",
    "ts-check": "NODE_OPTIONS=\"--max_old_space_size=8192\" tsc --noEmit -p ./tsconfig.json",
    "ts-check-build": "NODE_OPTIONS=\"--max_old_space_size=8192\" tsc -p ./tsconfig.build.json"
  },
  "browserslist": [
    ">0.1%",
    "not dead",
    "not op_mini all"
  ],
  "devDependencies": {
    "@emotion/css": "11.13.5",
    "@emotion/jest": "11.14.2",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@nivo/core": "0.99.0",
    "@nivo/line": "0.99.0",
    "@nivo/pie": "0.99.0",
    "@nivo/scales": "0.99.0",
    "@playwright/test": "1.57.0",
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.17",
    "html-webpack-plugin": "5.6.5"
  },
  "peerDependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@nivo/core": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@nivo/scales": "^0.99.0",
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x",
    "react-hook-form": "^7.46.1",
    "react-router-dom": "6.x || 7.x"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
