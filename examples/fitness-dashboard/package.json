{
  "name": "@ssa-ui-kit/fitness-dashboard",
  "version": "0.0.0",
  "main": "src/index.tsx",
  "private": true,
  "author": "SSA Group",
  "license": "MIT",
  "description": "Fitness Dashboard based on SSA UI Kit",
  "keywords": [
    "react",
    "SSA UI Kit",
    "Dashboard"
  ],
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@floating-ui/react": "0.27.4",
    "@nivo/core": "0.99.0",
    "@nivo/line": "0.99.0",
    "@nivo/pie": "0.99.0",
    "@nivo/scales": "0.99.0",
    "@ssa-ui-kit/core": "workspace:^",
    "@ssa-ui-kit/hooks": "workspace:^",
    "@ssa-ui-kit/widgets": "workspace:^",
    "dotenv": "16.0.3",
    "loose-envify": "1.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "7.10.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "./jest-setup.ts"
    ],
    "transform": {
      "^.+\\.(j|t)sx?$": "ts-jest"
    },
    "coveragePathIgnorePatterns": [
      "<rootDir>/src/apis/sources/mock/"
    ],
    "moduleNameMapper": {
      "^@components(.*)$": "<rootDir>/src/components$1",
      "^@apis(.*)$": "<rootDir>/src/apis$1",
      "^@hooks(.*)$": "<rootDir>/src/hooks$1"
    }
  },
  "scripts": {
    "test": "NODE_OPTIONS=\"--no-webstorage\" jest -i --no-cache",
    "build": "NODE_OPTIONS=\"--no-webstorage\" webpack --mode=production --node-env=production",
    "build:dev": "NODE_OPTIONS=\"--no-webstorage\" webpack --mode=development",
    "build:prod": "NODE_OPTIONS=\"--no-webstorage\" webpack --mode=production --node-env=production",
    "watch": "NODE_OPTIONS=\"--no-webstorage\" webpack --watch",
    "serve": "NODE_OPTIONS=\"--no-webstorage\" webpack serve",
    "create": "NODE_OPTIONS=\"--no-webstorage\" node ./tasks/create.js",
    "analyze": "NODE_OPTIONS=\"--no-webstorage\" webpack --profile --json > stats.json; NODE_OPTIONS=\"--no-webstorage\" webpack-bundle-analyzer ./stats.json",
    "analyze:prod": "NODE_OPTIONS=\"--no-webstorage\" webpack --mode=production --node-env=production --profile --json > stats.json; NODE_OPTIONS=\"--no-webstorage\" webpack-bundle-analyzer ./stats.json",
    "ts-show-config": "NODE_OPTIONS=\"--no-webstorage\" tsc --showConfig -p ./tsconfig.json",
    "ts-check": "NODE_OPTIONS=\"--no-webstorage\" tsc -p ./tsconfig.json"
  },
  "browserslist": [
    ">0.1%",
    "not dead",
    "not op_mini all"
  ],
  "devDependencies": {
    "@emotion/jest": "11.14.2",
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.17",
    "css-loader": "7.1.2",
    "html-webpack-plugin": "5.6.5",
    "style-loader": "4.0.0",
    "terser-webpack-plugin": "5.3.11",
    "webpack": "5.103.0"
  }
}
