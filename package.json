{
  "name": "@ssa-ui-kit/ui-kit-monorepo",
  "version": "2.32.0",
  "private": true,
  "description": "SSA UI Kit",
  "main": "index.js",
  "author": "SSA Group",
  "license": "MIT",
  "scripts": {
    "lint": "eslint .",
    "lint:styles": "stylelint \"**/*.tsx\"",
    "build:all": "pnpm -r build",
    "build:utils": "pnpm --filter ./packages/utils build",
    "build:hooks": "pnpm --filter ./packages/hooks build",
    "build:core": "pnpm --filter ./packages/core build",
    "build:core:watch": "pnpm --filter ./packages/core build:watch",
    "build:widgets": "pnpm --filter ./packages/widgets build",
    "build:templates": "pnpm --filter ./packages/templates build",
    "build:infra-dash": "pnpm --filter ./packages/infra-dash build",
    "spellcheck": "cspell \"**/*.{tsx,ts,md}\" --show-suggestions --no-progress",
    "test": "jest -i --no-cache",
    "test:coverage": "jest -i --no-cache --coverage",
    "test:update-snapshots": "jest -i --no-cache -u",
    "test:update-snapshots:parallel": "jest --no-cache -u --maxWorkers=50%",
    "test:e2e": "pnpm test:core:e2e && pnpm test:widgets:e2e",
    "test:core": "jest -i --no-cache --selectProjects \"UI Kit Core\"",
    "test:utils": "jest -i --no-cache --selectProjects \"UI Kit Utils\"",
    "test:hooks": "jest -i --no-cache --selectProjects \"UI Kit Hooks\"",
    "test:widgets": "jest -i --no-cache --selectProjects \"UI Kit Widgets\"",
    "test:templates": "jest -i --no-cache --selectProjects \"UI Kit Templates\"",
    "test:infra-dash": "jest -i --no-cache --selectProjects \"UI Kit InfraDash\"",
    "test:fitness": "echo 'TODO'",
    "test:clearcache": "jest --clearCache",
    "test:core:e2e": "pnpm --filter ./packages/core test:e2e",
    "test:core:e2e:ui": "pnpm --filter ./packages/core test:e2e:ui",
    "test:core:e2e:debug": "pnpm --filter ./packages/core test:e2e:debug",
    "test:widgets:e2e": "pnpm --filter ./packages/widgets test:e2e",
    "test:widgets:e2e:ui": "pnpm --filter ./packages/widgets test:e2e:ui",
    "test:widgets:e2e:debug": "pnpm --filter ./packages/widgets test:e2e:debug",
    "test:templates:e2e": "pnpm --filter ./packages/templates test:e2e",
    "test:templates:e2e:ui": "pnpm --filter ./packages/templates test:e2e:ui",
    "test:templates:e2e:debug": "pnpm --filter ./packages/templates test:e2e:debug",
    "test:infra-dash:e2e": "pnpm --filter ./packages/infra-dash test:e2e",
    "test:infra-dash:e2e:ui": "pnpm --filter ./packages/infra-dash test:e2e:ui",
    "test:infra-dash:e2e:debug": "pnpm --filter ./packages/infra-dash test:e2e:debug",
    "sb:dev": "env storybook dev -p 6001",
    "sb:dev:quiet": "env storybook dev -p 6001 --quiet",
    "sb:utils": "pnpm --filter ./packages/utils sb:dev",
    "sb:hooks": "pnpm --filter ./packages/hooks sb:dev",
    "sb:core": "pnpm --filter ./packages/core sb:dev",
    "sb:widgets": "pnpm --filter ./packages/widgets sb:dev",
    "sb:templates": "pnpm --filter ./packages/templates sb:dev",
    "sb:infra-dash": "pnpm --filter ./packages/infra-dash sb:dev",
    "sb:build:root": "env STORYBOOK_ENV=production storybook build",
    "sb:build:core": "pnpm --filter ./packages/core sb:build",
    "sb:build:widgets": "pnpm --filter ./packages/widgets sb:build",
    "sb:build:templates": "pnpm --filter ./packages/templates sb:build",
    "sb:build:infra-dash": "pnpm --filter ./packages/infra-dash sb:build",
    "sb:deploy:root": "vercel --prod  --archive=tgz",
    "sb:deploy:widgets": "pnpm sb:build:widgets && firebase deploy --only hosting:fitness",
    "sb:deploy:core": "pnpm sb:build:core && firebase deploy --only hosting:core",
    "sb:deploy:templates": "pnpm sb:build:templates && firebase deploy --only hosting:templates",
    "sb:deploy:infra-dash": "pnpm sb:build:infra-dash && firebase deploy --only hosting:infra-dash",
    "deploy:dashboard": "pnpm --filter ./examples/fitness-dashboard build && firebase deploy --only hosting:fitness-dashboard",
    "release": "tsx ./scripts/release",
    "prepare": "husky"
  },
  "keywords": [
    "react",
    "design system",
    "ui"
  ],
  "devDependencies": {
    "@babel/core": "7.26.9",
    "@babel/plugin-transform-runtime": "7.28.5",
    "@babel/preset-env": "7.28.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@babel/runtime": "7.26.9",
    "@commander-js/extra-typings": "13.1.0",
    "@emotion/babel-plugin": "11.13.5",
    "@emotion/jest": "11.14.2",
    "@eslint/compat": "1.4.1",
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.57.0",
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.17",
    "@storybook/addon-docs": "9.1.16",
    "@storybook/addon-links": "9.1.16",
    "@storybook/addon-webpack5-compiler-babel": "3.0.6",
    "@storybook/react-webpack5": "9.1.16",
    "@svgr/webpack": "8.1.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "29.5.2",
    "@types/node": "22.19.3",
    "@types/ramda": "0.30.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/sass": "1.45.0",
    "@typescript-eslint/eslint-plugin": "8.49.0",
    "@typescript-eslint/parser": "8.49.0",
    "babel-jest": "29.7.0",
    "babel-loader": "9.2.1",
    "commander": "13.1.0",
    "cspell": "8.19.4",
    "css-loader": "7.1.2",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-typescript": "3.0.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-storybook": "9.1.16",
    "firebase": "11.10.0",
    "globals": "15.15.0",
    "html-webpack-plugin": "5.6.5",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-cli": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-watch-typeahead": "2.2.2",
    "jsdom-testing-mocks": "1.16.0",
    "lint-staged": "15.5.2",
    "lost-pixel": "3.22.0",
    "postcss-styled-syntax": "0.7.1",
    "prettier": "3.7.4",
    "ramda": "0.30.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-refresh": "0.16.0",
    "react-router-dom": "7.10.1",
    "resize-observer-polyfill": "1.5.1",
    "resolve-tspaths": "0.8.23",
    "semver": "7.7.3",
    "simple-git": "3.30.0",
    "storybook": "9.1.16",
    "storybook-addon-pseudo-states": "9.1.16",
    "style-loader": "4.0.0",
    "stylelint": "16.26.1",
    "stylelint-config-standard": "37.0.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.49.0",
    "webpack": "5.103.0",
    "webpack-bundle-analyzer": "4.10.2",
    "webpack-cli": "6.0.1",
    "webpack-dev-server": "5.2.2",
    "webpack-node-externals": "3.0.0",
    "zx": "8.8.5"
  },
  "pnpm": {
    "overrides": {
      "nwsapi": "2.2.13"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@grafana/data>react": "19",
        "@grafana/data>react-dom": "19"
      }
    }
  },
  "packageManager": "pnpm@10.26.0"
}
